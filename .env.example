# XRPL (use testnet faucet: https://faucet.altnet.rippletest.net/)
ISSUER_SECRET=sEdXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
ISSUER_ADDRESS=

# Optional: override derived issuer address
# ISSUER_ADDRESS=rXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Network: testnet (default) or mainnet
# XRPL_NETWORK=testnet

# Xumm (for Buy signing - get at https://apps.xumm.dev/)
# XUMM_API_KEY=  (or XUMM_APIKEY)
# XUMM_API_SECRET=  (or XUMM_APISECRET)

# Pinata IPFS (get keys at https://app.pinata.cloud/developers/keys)
PINATA_JWT=
PINATA_GATEWAY=https://gateway.pinata.cloud

# Image generation - use one of:
# Replicate (recommended): get at https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=
# Gemini (alternative): get at https://aistudio.google.com/apikey
GEMINI_API_KEY=
